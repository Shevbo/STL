# Shectory Trader — env vars (copy to .shectory_trade.env, never commit)

# Finam Trade API
FINAM_BASE_URL=https://tradeapi.finam.ru
FINAM_SECRET_TOKEN=your_finam_api_token_here

# Auth bridge
SHECTORY_AUTH_BRIDGE_SECRET=your_shared_secret_here
SHECTORY_PORTAL_URL=https://shectory.ru

# App session
SHECTORY_SESSION_SECRET=your_random_session_secret_here

# Trading config
SHECTORY_MVP_SYMBOL=RIM6@RTSX
