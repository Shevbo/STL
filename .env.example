# Shectory Trader — env vars (copy to ~/.shectory_trade.env, never commit)
# Names match trader/config.py pydantic-settings fields exactly.

# Finam Trade API
FINAM_API_BASE_URL=https://api.finam.ru
FINAM_SECRET_TOKEN=your_finam_api_token_here
FINAM_ACCOUNT_ID=your_account_id_here
FINAM_MVP_SYMBOL=RIM6@RTSX

# Auth bridge (portal → trader)
SHECTORY_AUTH_BRIDGE_SECRET=your_shared_secret_here
SHECTORY_PORTAL_URL=https://shectory.ru

# GitHub (для деплоя и разработки — не читается приложением)
GITHUB_TOKEN_STL=your_github_pat_here
