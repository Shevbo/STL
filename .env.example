# Shectory Trader — env vars (copy to ~/.shectory_trade.env, never commit)
# Все имена зарегистрированы в Ключнике (keymaster на smain).
# Запрос метаданных: python3 ~/keymaster/keymaster.py --requester <id> query <NAME>

# --- Finam Trade API ---
FINAM_API_BASE_URL=https://api.finam.ru
FINAM_SECRET_TOKEN=                   # keymaster: FINAM_SECRET_TOKEN
FINAM_ACCOUNT_ID=                     # keymaster: FINAM_ACCOUNT_ID
FINAM_MVP_SYMBOL=RIM6@RTSX

# --- Auth bridge (trader <-> portal) ---
SHECTORY_AUTH_BRIDGE_SECRET=          # keymaster: SHECTORY_AUTH_BRIDGE_SECRET
SHECTORY_PORTAL_URL=https://shectory.ru

# --- Local fallback user (опционально) ---
SHECTORY_LOCAL_USER_EMAIL=
SHECTORY_LOCAL_USER_PASSWORD_SHA256=  # keymaster: SHECTORY_LOCAL_USER_PASSWORD_SHA256

# --- GitHub (деплой, не читается приложением) ---
GITHUB_TOKEN_STL=                     # keymaster: GITHUB_TOKEN_STL
